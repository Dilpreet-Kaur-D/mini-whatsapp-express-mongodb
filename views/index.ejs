<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini-Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <div class="start">
        <h2>All Chats</h2>
        <form method="get" action="/chats/new">
            <button>Continue Chat</button>
        </form>
    </div>
    <%for(let chat of chats){%>
        <div class="chat">
            <p>From: <i>
                    <%= chat.from %>
                </i>
            </p>
            <div class="messagebox">
                <p>
                    <%= chat.msg %>
                </p>
                <div class="btns">
                <form method="get" action="/chats/<%= chat._id %>/edit">
                    <button>Edit Chat</button>
                </form>
                <form method="post" action="/chats/<%= chat._id %>?_method=DELETE">
                    <button class="delete">Delete Chat</button>
                </form>
                </div>
            </div>
            <p>✔️ Received by <i>
                    <%= chat.to %>
                </i>
            </p>
            <hr>
            <p>
                <%= chat.created_at.toString().split(" ")[4] %></p>
            <!-- chat.created_at.toString().split(" ")---this became array now where every element is comma separated -->
<p><%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %></p>
        </div>
        <br>

        <% } %>
</body>

</html>